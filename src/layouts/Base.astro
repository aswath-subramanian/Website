---
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-sans/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/600.css';
import { url } from '../lib/url';

const {
  title = "Aswath Subramanian",
  description = "Notes and open work on where engineering promises meet reality.",
  type = "website",
  wide = false,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <link rel="icon" href={url('/favicon.svg')} type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="Ground Truth: claims vs. measured reality" href={url('/ground-truth/rss.xml')} />
  <link rel="alternate" type="application/rss+xml" title="Finding My Joule: a wider notebook" href={url('/finding-my-joule/rss.xml')} />
  <style is:global>
    :root {
      --ink:#1a1a1a; --muted:#6f6f6f; --line:#e4e4e4; --bg:#fafafa; --accent:#2d4f9e;
      --sans:'IBM Plex Sans', system-ui, -apple-system, sans-serif;
      --mono:'IBM Plex Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      color-scheme: light dark;
    }
    @media (prefers-color-scheme: dark) {
      :root { --ink:#e5e7ea; --muted:#a2a4a8; --line:#303236; --bg:#141516; --accent:#8aa5e8; }
    }
    * { box-sizing:border-box; }
    @view-transition { navigation: auto; }
    nav.site { view-transition-name: site-nav; }
    footer.site { view-transition-name: site-footer; }
    ::selection { background:var(--accent); color:var(--bg); }
    body { margin:0; background:var(--bg); color:var(--ink);
      font-family:var(--sans); font-size:17px; line-height:1.65;
      -webkit-font-smoothing:antialiased; }
    .wrap { max-width:680px; margin:0 auto; padding:0 24px; }
    .wrap.wide { max-width:1000px; }
    .skip { position:absolute; left:-9999px; top:0; z-index:10; background:var(--bg); color:var(--ink); padding:8px 14px; border:1px solid var(--line); font-family:var(--mono); font-size:13px; }
    .skip:focus { left:12px; top:12px; }
    nav.site { display:flex; justify-content:space-between; align-items:baseline; padding:32px 0 56px; gap:16px; flex-wrap:wrap; font-family:var(--mono); width:100%; max-width:632px; margin:0 auto; }
    nav.site a.name { font-weight:600; font-size:14px; text-decoration:none; color:var(--ink); }
    nav.site .links { display:flex; gap:20px; flex-wrap:wrap; }
    nav.site .links a { color:var(--muted); text-decoration:none; font-size:13px; }
    nav.site .links a:hover { color:var(--ink); }
    h1 { font-size:clamp(25px, 3vw + 14px, 30px); line-height:1.3; font-weight:600; letter-spacing:-0.01em; margin:0 0 20px; }
    h2 { font-size:22px; line-height:1.35; font-weight:600; letter-spacing:-0.005em; margin:44px 0 12px; }
    h3 { font-size:19px; font-weight:600; margin:32px 0 8px; }
    h4 { font-size:17px; font-weight:600; margin:28px 0 8px; }
    .kicker { font-family:var(--mono); font-size:12px; font-weight:600; text-transform:uppercase; letter-spacing:0.12em; color:var(--muted); margin:56px 0 14px; }
    p { margin:0 0 18px; }
    a { color:var(--ink); text-decoration:underline; text-decoration-color:var(--accent); text-decoration-thickness:1px; text-underline-offset:3px; }
    a:hover { text-decoration-color:var(--ink); }
    .lead { font-size:19px; line-height:1.6; }
    .muted { color:var(--muted); }
    ul, ol { margin:0 0 18px; padding-left:26px; }
    li { margin:0 0 6px; }
    ul.bare { list-style:none; padding:0; margin:0; }
    ul.bare li { margin:0; }
    img { max-width:100%; height:auto; }
    figure { margin:0 0 18px; }
    figcaption { font-family:var(--mono); color:var(--muted); font-size:12.5px; margin-top:6px; }
    code { font-family:var(--mono); font-size:0.85em; }
    pre { overflow-x:auto; padding:14px 16px; border:1px solid var(--line); margin:0 0 18px; line-height:1.55; }
    pre code { font-size:14px; }
    blockquote { margin:0 0 18px; padding:0 0 0 16px; border-left:1px solid var(--muted); }
    table { display:block; overflow-x:auto; border-collapse:collapse; margin:0 0 18px; font-family:var(--mono); font-size:13.5px; }
    th, td { padding:8px 16px 8px 0; border-bottom:1px solid var(--line); text-align:left; vertical-align:top; }
    th { font-weight:600; }
    hr { border:0; border-top:1px solid var(--line); margin:44px 0; }
    .entry { display:flex; justify-content:space-between; align-items:baseline; gap:16px; padding:13px 0; border-bottom:1px solid var(--line); }
    .entry a { text-decoration:none; }
    .entry a:hover { text-decoration:underline; text-decoration-color:var(--accent); }
    .entry .date { font-family:var(--mono); color:var(--muted); font-size:13px; white-space:nowrap; }
    .entry .status { color:var(--accent); }
    article.note .date { font-family:var(--mono); color:var(--muted); font-size:13px; margin:0 0 32px; display:block; }
    .home-grid { display:flex; flex-direction:column; gap:40px; }
    @media (min-width:800px) {
      .home-grid { display:grid; grid-template-columns:240px minmax(0,1fr); gap:56px; align-items:start; }
    }
    .rail .portrait { display:block; width:100%; max-width:240px; height:auto; border:1px solid var(--line); filter:grayscale(12%); }
    .rail-name { font-family:var(--mono); font-weight:600; font-size:14px; margin:16px 0 4px; }
    .rail-role { font-size:14.5px; line-height:1.55; color:var(--muted); margin:0 0 14px; }
    .rail-links { list-style:none; padding:0; margin:0; font-family:var(--mono); font-size:12.5px; }
    .rail-links li { margin:0 0 7px; }
    .proj { margin:0 0 16px; }
    .proj-name { font-family:var(--mono); font-size:14px; font-weight:600; margin:0 0 2px; }
    .proj-tag { font-weight:400; font-size:12px; color:var(--accent); margin-left:8px; }
    .proj-desc { font-size:15px; color:var(--muted); margin:0; }
    @media (prefers-reduced-motion: reduce) {
      ::view-transition-group(*), ::view-transition-old(*), ::view-transition-new(*) { animation:none !important; }
    }
    .share { display:flex; align-items:baseline; gap:18px; flex-wrap:wrap; margin-top:56px; font-family:var(--mono); font-size:12.5px; }
    .share-label { text-transform:uppercase; letter-spacing:0.12em; font-size:11px; color:var(--muted); }
    .share a, .share button { background:none; border:0; padding:0; font:inherit; color:var(--muted); cursor:pointer;
      text-decoration:underline; text-decoration-color:var(--accent); text-underline-offset:3px; }
    .share a:hover, .share button:hover { color:var(--ink); text-decoration-color:var(--ink); }
    footer.site { margin:80px auto 48px; width:100%; max-width:632px; color:var(--muted); font-size:13px; font-family:var(--mono); border-top:1px solid var(--line); padding-top:22px; }
    footer.site a { color:var(--muted); }
  </style>
</head>
<body>
  <div class={wide ? 'wrap wide' : 'wrap'}>
    <a class="skip" href="#main">Skip to content</a>
    <nav class="site">
      <a class="name" href={url('/')}>Aswath Subramanian</a>
      <span class="links">
        <a href={url('/ground-truth/')}>Ground Truth</a>
        <a href={url('/finding-my-joule/')}>Finding My Joule</a>
        <a href={url('/about/')}>About</a>
      </span>
    </nav>
    <main id="main">
      <slot />
    </main>
    <footer class="site">© Aswath Subramanian · <a href="mailto:contact@aswath.nl">contact@aswath.nl</a></footer>
  </div>
</body>
</html>
