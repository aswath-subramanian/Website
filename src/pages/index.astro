---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { url } from '../lib/url';
import { projects } from '../data/projects';
import portrait from '../assets/portrait.jpg';
const gt = (await getCollection('groundtruth')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmj = (await getCollection('fmj')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestGt = gt[0];
const latestFmj = fmj[0];
---
<Base wide={true}>
  <div class="home-grid">
    <aside class="rail">
      <Image class="portrait" src={portrait} alt="Portrait of Aswath Subramanian" width={480} height={480} />
      <p class="rail-name">Aswath Subramanian</p>
      <p class="rail-role">Engineer: thin-film PV, high-volume manufacturing, and the awkward passage from lab validation to factory floor.</p>
      <ul class="rail-links">
        <li><a href="mailto:contact@aswath.nl">contact@aswath.nl</a></li>
        <li><a href="https://www.linkedin.com/in/aswath-subramanian/">LinkedIn</a></li>
        <li><a href="https://github.com/aswath-subramanian">GitHub</a></li>
      </ul>
    </aside>

    <div>
      <h1>I look for where engineering promises break: in scale-up, in emissions numbers, in the claims we build systems on.</h1>

      <div>
        <h2 class="kicker">Ground Truth</h2>
        <p>Engineering and climate claims, put next to measured reality: whether the numbers we build on are real.</p>
        {latestGt && (
          <p class="muted">Latest: <a href={url(`/ground-truth/${latestGt.id}/`)} style={`view-transition-name: t-${latestGt.id}`}>{latestGt.data.title}</a></p>
        )}

        <h2 class="kicker">Finding My Joule</h2>
        <p>A wider notebook: energy, engineering, process, and tangents. Any register.</p>
        {latestFmj && (
          <p class="muted">Latest: <a href={url(`/finding-my-joule/${latestFmj.id}/`)} style={`view-transition-name: t-${latestFmj.id}`}>{latestFmj.data.title}</a></p>
        )}

        {projects.length > 0 && (
          <>
            <h2 class="kicker">Projects</h2>
            {projects.map((p) => (
              <div class="proj">
                <p class="proj-name"><a href={p.href}>{p.name}</a>{p.tag && <span class="proj-tag">{p.tag}</span>}</p>
                <p class="proj-desc">{p.desc}</p>
              </div>
            ))}
          </>
        )}
      </div>
    </div>
  </div>
</Base>
