---
const { title } = Astro.props;
const shareUrl = new URL(Astro.url.pathname, Astro.site).href;
const linkedin = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(shareUrl)}`;
const whatsapp = `https://wa.me/?text=${encodeURIComponent(`${title} · ${shareUrl}`)}`;
---
<div class="share">
  <span class="share-label">share</span>
  <button class="share-copy" data-url={shareUrl}>copy link</button>
  <button class="share-native" hidden data-title={title} data-url={shareUrl}>share&#8230;</button>
  <a href={linkedin}>LinkedIn</a>
  <a href={whatsapp}>WhatsApp</a>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(btn.dataset.url ?? '');
      const label = btn.textContent;
      btn.textContent = 'copied';
      setTimeout(() => {
        btn.textContent = label;
      }, 1600);
    });
  });
  const native = document.querySelector<HTMLButtonElement>('.share-native');
  if (native && navigator.share) {
    native.hidden = false;
    native.addEventListener('click', () => {
      navigator.share({ title: native.dataset.title, url: native.dataset.url });
    });
  }
</script>
