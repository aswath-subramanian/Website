---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';

const {
  title = "Aswath Subramanian",
  description = "Notes and open work on where engineering promises meet reality.",
  type = "website",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="alternate" type="application/rss+xml" title="Ground Truth — measuring superpollutants honestly" href="/ground-truth/rss.xml" />
  <link rel="alternate" type="application/rss+xml" title="Finding My Joule — a wider notebook" href="/finding-my-joule/rss.xml" />
  <style is:global>
    :root {
      --ink:#1a1a1a; --muted:#6f6f6f; --line:#e6e6e3; --bg:#fdfdfb;
      color-scheme: light dark;
    }
    @media (prefers-color-scheme: dark) {
      :root { --ink:#e7e7e4; --muted:#a3a39e; --line:#333330; --bg:#151514; }
    }
    * { box-sizing:border-box; }
    body { margin:0; background:var(--bg); color:var(--ink);
      font-family:Inter,system-ui,-apple-system,sans-serif; font-size:17px; line-height:1.65;
      -webkit-font-smoothing:antialiased; }
    .wrap { max-width:680px; margin:0 auto; padding:0 24px; }
    .skip { position:absolute; left:-9999px; top:0; z-index:10; background:var(--bg); color:var(--ink); padding:8px 14px; border:1px solid var(--line); }
    .skip:focus { left:12px; top:12px; }
    nav.site { display:flex; justify-content:space-between; align-items:baseline; padding:32px 0 56px; gap:16px; flex-wrap:wrap; }
    nav.site a.name { font-weight:600; text-decoration:none; color:var(--ink); }
    nav.site .links { display:flex; gap:20px; flex-wrap:wrap; }
    nav.site .links a { color:var(--muted); text-decoration:none; font-size:15px; }
    nav.site .links a:hover { color:var(--ink); }
    h1 { font-size:29px; line-height:1.3; font-weight:600; letter-spacing:-0.01em; margin:0 0 20px; }
    h2 { font-size:22px; line-height:1.35; font-weight:600; letter-spacing:-0.01em; margin:44px 0 12px; }
    h3 { font-size:19px; font-weight:600; margin:32px 0 8px; }
    h4 { font-size:17px; font-weight:600; margin:28px 0 8px; }
    .kicker { font-size:13px; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:var(--muted); margin:56px 0 14px; }
    p { margin:0 0 18px; }
    a { color:var(--ink); text-decoration:underline; text-decoration-color:var(--muted); text-underline-offset:3px; }
    a:hover { text-decoration-color:var(--ink); }
    .lead { font-size:20px; }
    .muted { color:var(--muted); }
    ul, ol { margin:0 0 18px; padding-left:26px; }
    li { margin:0 0 6px; }
    ul.bare { list-style:none; padding:0; margin:0; }
    ul.bare li { margin:0; }
    img { max-width:100%; height:auto; }
    figure { margin:0 0 18px; }
    figcaption { color:var(--muted); font-size:14px; margin-top:6px; }
    code { font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace; font-size:0.88em; }
    pre { overflow-x:auto; padding:14px 16px; border:1px solid var(--line); margin:0 0 18px; line-height:1.55; }
    pre code { font-size:14px; }
    blockquote { margin:0 0 18px; padding:0 0 0 16px; border-left:1px solid var(--muted); }
    table { display:block; overflow-x:auto; border-collapse:collapse; margin:0 0 18px; font-size:15px; }
    th, td { padding:8px 16px 8px 0; border-bottom:1px solid var(--line); text-align:left; vertical-align:top; }
    th { font-weight:600; }
    hr { border:0; border-top:1px solid var(--line); margin:44px 0; }
    .entry { display:flex; justify-content:space-between; align-items:baseline; gap:16px; padding:13px 0; border-bottom:1px solid var(--line); }
    .entry a { text-decoration:none; }
    .entry a:hover { text-decoration:underline; }
    .entry .date { color:var(--muted); font-size:14px; white-space:nowrap; }
    article.note .date { color:var(--muted); font-size:14px; margin:0 0 32px; display:block; }
    footer.site { margin:80px 0 48px; color:var(--muted); font-size:14px; border-top:1px solid var(--line); padding-top:22px; }
    footer.site a { color:var(--muted); }
  </style>
</head>
<body>
  <div class="wrap">
    <a class="skip" href="#main">Skip to content</a>
    <nav class="site">
      <a class="name" href="/">Aswath Subramanian</a>
      <span class="links">
        <a href="/ground-truth/">Ground Truth</a>
        <a href="/finding-my-joule/">Finding My Joule</a>
        <a href="/about/">About</a>
      </span>
    </nav>
    <main id="main">
      <slot />
    </main>
    <footer class="site">© Aswath Subramanian · <a href="mailto:contact@aswath.nl">contact@aswath.nl</a></footer>
  </div>
</body>
</html>
