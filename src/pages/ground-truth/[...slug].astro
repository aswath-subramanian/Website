---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { isoDate, formatDate } from '../../lib/dates';

export async function getStaticPaths() {
  const entries = await getCollection('groundtruth');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title} description={entry.data.description} type="article">
  <article class="note">
    <h1>{entry.data.title}</h1>
    <span class="date">{entry.data.status ? entry.data.status + ' · ' : ''}<time datetime={isoDate(entry.data.date)}>{formatDate(entry.data.date)}</time></span>
    <Content />
  </article>
</Base>
